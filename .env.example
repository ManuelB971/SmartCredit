# Smart Crédit Environment Variables
# Copy this to .env and fill in your values

# Django
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=smart_credit_db
DB_USER=smart_credit_user
DB_PASSWORD=your_database_password_here
DB_HOST=localhost
DB_PORT=5432

# IA — Groq API (Recommended)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192

# IA — Hugging Face (Alternative)
HF_API_KEY=your_huggingface_api_key_here
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
DEFAULT_FROM_EMAIL=noreply@smartcredit.fr

# PDF Storage
PDF_STORAGE_PATH=media/pdf/

# Redis (optional, for caching/tasks)
REDIS_URL=redis://localhost:6379/0

# Sentry (optional, for error tracking)
SENTRY_DSN=your-sentry-dsn-here
